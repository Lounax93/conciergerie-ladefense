{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/revenus-airbnb-la-defense-2026", "destination": "/blog/revenus-airbnb-la-defense-2026", "permanent": true },
    { "source": "/lmnp-la-defense-guide-fiscal-2026", "destination": "/blog/lmnp-la-defense-guide-fiscal-2026", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
